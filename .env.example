VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Lovable's generated client also reads VITE_SUPABASE_PUBLISHABLE_KEY as an
# alias for the anon key. Set both to the same value for maximum compatibility.
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_SUPABASE_PROJECT_ID=your_supabase_project_ref

# Server-side (used by SSR / server functions). Same values as above.
SUPABASE_URL=your_supabase_project_url
SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
# Required only if you use admin server functions that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key